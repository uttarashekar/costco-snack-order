# Copy this file to .env and fill in your values
# cp .env.sample .env

# Your delivery address (as you'd type it into Costco Same Day)
DELIVERY_ADDRESS=123 Main St, Seattle, WA 98101

# Chrome debug port (default 9222)
CDP_PORT=9222

# Anthropic API key for LLM-based product matching (optional, falls back to keyword matching)
ANTHROPIC_API_KEY=